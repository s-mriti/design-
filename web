<script>
gsap.registerPlugin(ScrollTrigger);

// CURSOR
const cursor = document.getElementById('cursor');
const cursorRing = document.getElementById('cursorRing');
let mouseX = 0, mouseY = 0, ringX = 0, ringY = 0;
document.addEventListener('mousemove', e => { mouseX = e.clientX; mouseY = e.clientY; });
(function animCursor() {
  cursor.style.left = mouseX + 'px'; cursor.style.top = mouseY + 'px';
  ringX += (mouseX - ringX) * 0.12; ringY += (mouseY - ringY) * 0.12;
  cursorRing.style.left = ringX + 'px'; cursorRing.style.top = ringY + 'px';
  requestAnimationFrame(animCursor);
})();
document.querySelectorAll('a, button, .service-card, .program-item, .dosha-card').forEach(el => {
  el.addEventListener('mouseenter', () => { cursor.style.width='16px';cursor.style.height='16px';cursor.style.background='#fff'; });
  el.addEventListener('mouseleave', () => { cursor.style.width='8px';cursor.style.height='8px';cursor.style.background='var(--gold)'; });
});

// THREE.JS HERO
(function initHero() {
  const canvas = document.getElementById('three-canvas');
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  const w = canvas.clientWidth, h = canvas.clientHeight;
  renderer.setSize(w, h);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(60, w / h, 0.1, 100);
  camera.position.set(0, 0, 5);

  // Lotus / mandala geometry — torus knot clusters
  const group = new THREE.Group();
  scene.add(group);

  const mat1 = new THREE.MeshBasicMaterial({ color: 0xd4a843, wireframe: true, transparent: true, opacity: 0.15 });
  const mat2 = new THREE.MeshBasicMaterial({ color: 0x7a9e7e, wireframe: true, transparent: true, opacity: 0.1 });
  const mat3 = new THREE.MeshBasicMaterial({ color: 0xc4956a, wireframe: true, transparent: true, opacity: 0.08 });

  const t1 = new THREE.Mesh(new THREE.TorusKnotGeometry(1.6, 0.3, 180, 20, 3, 5), mat1);
  const t2 = new THREE.Mesh(new THREE.TorusKnotGeometry(2.2, 0.15, 160, 16, 5, 3), mat2);
  const t3 = new THREE.Mesh(new THREE.TorusGeometry(2.8, 0.04, 8, 120), mat3);
  const t4 = new THREE.Mesh(new THREE.TorusGeometry(3.4, 0.02, 8, 120), mat3);
  const t5 = new THREE.Mesh(new THREE.IcosahedronGeometry(1, 2), new THREE.MeshBasicMaterial({ color: 0xd4a843, wireframe: true, transparent: true, opacity: 0.06 }));

  group.add(t1, t2, t3, t4, t5);
  group.position.set(3, 0, -1);

  // Floating particles
  const pts = [];
  for (let i = 0; i < 300; i++) {
    pts.push((Math.random()-0.5)*14, (Math.random()-0.5)*10, (Math.random()-0.5)*8);
  }
  const partGeo = new THREE.BufferGeometry();
  partGeo.setAttribute('position', new THREE.Float32BufferAttribute(pts, 3));
  const partMesh = new THREE.Points(partGeo, new THREE.PointsMaterial({ color: 0xd4a843, size: 0.025, transparent: true, opacity: 0.5 }));
  scene.add(partMesh);

  let mx = 0, my = 0;
  document.addEventListener('mousemove', e => { mx = (e.clientX/window.innerWidth-.5)*2; my = -(e.clientY/window.innerHeight-.5)*2; });

  function render(t) {
    requestAnimationFrame(render);
    t *= 0.001;
    t1.rotation.x = t * 0.3; t1.rotation.y = t * 0.5;
    t2.rotation.x = -t * 0.2; t2.rotation.z = t * 0.4;
    t3.rotation.z = t * 0.15;
    t4.rotation.z = -t * 0.1;
    t5.rotation.x = t * 0.4; t5.rotation.y = t * 0.3;
    group.rotation.y += (mx * 0.3 - group.rotation.y) * 0.04;
    group.rotation.x += (my * 0.2 - group.rotation.x) * 0.04;
    partMesh.rotation.y = t * 0.05;
    renderer.render(scene, camera);
  }
  render(0);

  window.addEventListener('resize', () => {
    const w2 = canvas.clientWidth, h2 = window.innerHeight;
    camera.aspect = w2 / h2;
    camera.updateProjectionMatrix();
    renderer.setSize(w2, h2);
  });
})();

// THREE.JS MINDFULNESS SPHERE
(function initMind() {
  const canvas = document.getElementById('mind-canvas');
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  const w = canvas.clientWidth, h = canvas.clientHeight;
  renderer.setSize(w, h);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(55, 1, 0.1, 100);
  camera.position.z = 3.5;

  const geo = new THREE.SphereGeometry(1.2, 64, 64);
  const mat = new THREE.MeshBasicMaterial({ color: 0x7a9e7e, wireframe: true, transparent: true, opacity: 0.25 });
  const sphere = new THREE.Mesh(geo, mat);

  const inner = new THREE.Mesh(
    new THREE.SphereGeometry(0.85, 32, 32),
    new THREE.MeshBasicMaterial({ color: 0xd4a843, wireframe: true, transparent: true, opacity: 0.15 })
  );

  const ring1 = new THREE.Mesh(new THREE.TorusGeometry(1.5, 0.012, 8, 120), new THREE.MeshBasicMaterial({ color: 0xd4a843, transparent: true, opacity: 0.3 }));
  const ring2 = new THREE.Mesh(new THREE.TorusGeometry(1.75, 0.008, 8, 120), new THREE.MeshBasicMaterial({ color: 0xc4956a, transparent: true, opacity: 0.2 }));
  ring1.rotation.x = Math.PI / 2.5;
  ring2.rotation.x = -Math.PI / 3;

  scene.add(sphere, inner, ring1, ring2);

  function render(t) {
    requestAnimationFrame(render);
    t *= 0.001;
    sphere.rotation.y = t * 0.2;
    sphere.rotation.x = t * 0.1;
    inner.rotation.y = -t * 0.3;
    inner.rotation.z = t * 0.15;
    ring1.rotation.z = t * 0.1;
    ring2.rotation.y = t * 0.08;
    renderer.render(scene, camera);
  }
  render(0);
})();

// NAV SCROLL
window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 80);
});

// HERO ENTRANCE
gsap.timeline({ delay: 0.3 })
  .to('.hero-eyebrow', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' })
  .to('.hero-title', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' }, '-=0.5')
  .to('.hero-sub', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.6')
  .to('.hero-btns', { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.5')
  .to('.scroll-indicator', { opacity: 1, duration: 0.6 }, '-=0.2');

// SCROLL REVEALS
gsap.utils.toArray('.reveal').forEach(el => {
  gsap.fromTo(el,
    { opacity: 0, y: 50 },
    { opacity: 1, y: 0, duration: 1, ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 82%', toggleActions: 'play none none none' } }
  );
});
gsap.utils.toArray('.reveal-left').forEach(el => {
  gsap.fromTo(el,
    { opacity: 0, x: -50 },
    { opacity: 1, x: 0, duration: 1, ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 82%', toggleActions: 'play none none none' } }
  );
});

// SERVICE CARDS STAGGER
gsap.fromTo('.service-card',
  { opacity: 0, scale: 0.92 },
  { opacity: 1, scale: 1, duration: 0.7, stagger: 0.1, ease: 'power3.out',
    scrollTrigger: { trigger: '.services-grid', start: 'top 75%' } }
);

// COUNTER ANIMATION
document.querySelectorAll('[data-target]').forEach(el => {
  ScrollTrigger.create({
    trigger: el, start: 'top 85%', once: true,
    onEnter: () => {
      const target = +el.dataset.target;
      gsap.to({ val: 0 }, {
        val: target, duration: 2, ease: 'power2.out',
        onUpdate: function() { el.textContent = Math.round(this.targets()[0].val).toLocaleString(); }
      });
    }
  });
});

// PROGRAM ITEMS STAGGER
gsap.fromTo('.program-item',
  { opacity: 0, x: -30 },
  { opacity: 1, x: 0, duration: 0.6, stagger: 0.12, ease: 'power2.out',
    scrollTrigger: { trigger: '.programs-list', start: 'top 78%' } }
);

// TESTIMONIAL INFINITE SCROLL
const slider = document.getElementById('testiSlider');
let sliderPos = 0;
const totalW = slider.scrollWidth / 2;
function animSlider() {
  sliderPos += 0.5;
  if (sliderPos >= totalW) sliderPos = 0;
  slider.scrollLeft = sliderPos;
  requestAnimationFrame(animSlider);
}
// Clone cards
const cards = Array.from(slider.children);
cards.forEach(c => slider.appendChild(c.cloneNode(true)));
slider.addEventListener('mouseenter', () => sliderPos += 0);
requestAnimationFrame(animSlider);

// PARALLAX HERO TEXT
gsap.to('.hero-content', {
  y: -100, ease: 'none',
  scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: true }
});

// DOSHA CARD HOVER GSAP
document.querySelectorAll('.dosha-card').forEach(card => {
  card.addEventListener('mouseenter', () => gsap.to(card, { scale: 1.02, duration: 0.3 }));
  card.addEventListener('mouseleave', () => gsap.to(card, { scale: 1, duration: 0.3 }));
});
</script>
